# App
NODE_ENV=development
PORT=3001
CLIENT_PORT=5173

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ias_hub
DB_USER=ias_hub_user
DB_PASS=your_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth — must match PLANet Contact IAS JWT_SECRET
JWT_SECRET=your_shared_jwt_secret_here

# PLANet Contact IAS API
PCI_API_URL=https://ias-app.planetsg.com

# Whisper AI (local transcription service)
WHISPER_API_URL=http://localhost:9000

# mediasoup WebRTC
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# Jira (Atlassian MCP)
JIRA_CLOUD_ID=016ccab4-41b8-4069-b389-0e6f7385b912
JIRA_PROJECT_KEY=IAS
