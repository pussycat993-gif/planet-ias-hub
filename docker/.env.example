# ─────────────────────────────────────────────
# IAS Hub — Environment Variables
# Copy this file to .env and fill in all values
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3001
TENANT_ID=default

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ias_hub
DB_USER=ias_hub_user
DB_PASS=change_this_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth — MUST match PLANet Contact IAS JWT_SECRET
JWT_SECRET=change_this_to_a_strong_secret_min_32_chars

# PLANet Contact IAS
PCI_API_URL=https://ias-app.planetsg.com

# Whisper AI (local transcription)
WHISPER_API_URL=http://localhost:9000

# mediasoup WebRTC
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# Jira (Atlassian MCP — read only)
JIRA_CLOUD_ID=016ccab4-41b8-4069-b389-0e6f7385b912
JIRA_PROJECT_KEY=IAS

# Email (for standalone user password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@iashub.local
